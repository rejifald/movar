{
  "$schema": "https://fallow.dev/schema/fallow-config.json",
  "entry": [
    "apps/extension/src/entrypoints/**/*.{ts,tsx,html}",
    "apps/extension/wxt.config.ts",
    // Dynamic content-script capabilities are built as separate, web-accessible
    // chunks by wxt.config's bundleCapabilityChunks; content.ts pulls them in
    // via import(runtime.getURL(...)), which static analysis can't trace.
    "apps/extension/src/dynamic/features/*.ts",
    "apps/extension/src/sites/*/model.ts",
    "apps/diagnostics/src/entrypoints/**/*.{ts,tsx,html}",
    "apps/diagnostics/wxt.config.ts",
    // Cloudflare Pages Functions are file-routed entry points invoked by the
    // Pages runtime, not imported — without this they read as "unused files".
    "apps/marketing/functions/**/*.ts"
  ],
  "ignorePatterns": [
    "apps/extension/src/styles/**",
    "apps/extension/src/vite-env.d.ts",
    "apps/diagnostics/src/styles/**",
    "apps/diagnostics/src/vite-env.d.ts",
    "**/*.fixture.html",
    "apps/extension/preview/**",
    "apps/extension/scripts/**",
    "apps/e2e/playwright.*.ts",
    // The diagnostics e2e visual harness — its source dir plus the standalone
    // Vite config that builds it (invoked by project.json's build:harness, not
    // imported) — is loaded over file:// by apps/e2e. No import edge fallow can
    // trace, so it reads as unreachable "dead code"; it's test scaffolding, like
    // the playwright configs above.
    "apps/diagnostics/e2e-harness/**",
    "apps/diagnostics/vite.harness.config.ts",
    "apps/extension/safari/**/Resources/**",
    "scripts/**",
    "apps/extension/src/test/**"
  ],
  "ignoreDependencies": [
    "@wxt-dev/module-react",
    "publint",
    // CSS-only deps — imported via `@import` in style files that fallow's
    // dead-code tracer doesn't follow. The fonts land in `src/styles/**`
    // (ignored above); `@movar/theme` is consumed the same way (diagnostics'
    // only usage is its ignored `src/styles/globals.css`), so it reads as
    // unused despite being required to resolve the token stylesheets.
    "@fontsource/manrope",
    "@fontsource/ibm-plex-mono",
    "@movar/theme"
  ],
  // Inline `// fallow-ignore-*` comments are further governed by
  // scripts/check-suppressions.mts (run from `pnpm validate` + lefthook):
  // only allow-listed rules may be suppressed inline, each needs a `-- reason`,
  // file-level suppressions are banned, and the total count is budgeted.
  "rules": {
    // A `fallow-ignore` that no longer matches a live finding is dead weight
    // that silently hides the next real issue on that line — fail, don't warn.
    "stale-suppressions": "error"
  },
  "health": {
    // Stop emitting `suppress-line` hints in JSON output: scripts/fallow-targets.mts
    // feeds this JSON to refactoring agents, and we don't want them nudged into
    // adding a complexity ignore instead of reducing complexity.
    "suggestInlineSuppression": false,
    // Complexity/maintainability health measures hand-written, shipped product
    // and library source. Excluded below: tests (long describe/it callbacks +
    // repeated setup — same stance as `duplicates.ignore` and eslint-config-movar,
    // where heavy rules only fire on first-class source), the e2e harness app,
    // Storybook stories, and the Chrome-Web-Store screenshot storyboards (visual
    // fixtures that mirror real sites by design — like the already-ignored
    // `scripts/`, `preview/`, and `*.fixture.html`). This only scopes the health
    // pipeline; every file still counts as a reference for dead-code analysis.
    "ignore": [
      "**/*.test.ts",
      "**/*.test.tsx",
      "**/*.spec.ts",
      "**/*.spec.tsx",
      "apps/e2e/**",
      "apps/extension/store-assets/**",
      "apps/marketing/scripts/**",
      "**/*.stories.tsx"
    ]
  },
  "duplicates": {
    // Tests intentionally repeat setup (same stance as eslint-config-movar, where
    // the heavy rules only fire on first-class source). Excluding them here
    // replaces four file-level `// fallow-ignore-file code-duplication` comments.
    // `*.spec.*` carries the Playwright e2e suites — same "tests repeat setup" intent.
    //
    // The two source files below carry intentional structural parallels that can't
    // collapse without harm (see each file's header comment): PrioritySection mirrors
    // BlockedSection by design; active.ts mirrors classify.ts's loop but can't share a
    // helper without an import cycle. File-level inline suppression is banned
    // (scripts/check-suppressions.mts), so the exemption is recorded here instead.
    "ignore": [
      "**/*.test.ts",
      "**/*.test.tsx",
      "**/*.spec.ts",
      "**/*.spec.tsx",
      "packages/options-ui/src/PrioritySection.tsx",
      "packages/lang-pickers/src/active.ts"
    ]
  }
}
