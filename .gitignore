storybook-static

# Isolated-agent git worktrees (full repo checkouts the harness creates under
# .claude/). They're linked worktrees, not content of this one — keep them out
# of `git status` and out of every .gitignore-respecting tool's tree walk
# (eslint ., prettier ., ripgrep, editor indexing). Nx is handled separately in
# .nxignore.
.claude/worktrees/

# Vendored Cloudflare platform skills (installed locally via the skills
# marketplace, reinstallable anytime). They're generic upstream docs, not
# movar-specific automation like the tracked add-before-after-case / sync-readme
# skills, so keep them on disk for local use but out of version control.
.claude/skills/agents-sdk/
.claude/skills/cloudflare/
.claude/skills/cloudflare-email-service/
.claude/skills/durable-objects/
.claude/skills/sandbox-sdk/
.claude/skills/workers-best-practices/
.claude/skills/wrangler/

# demo-video recording outputs — captured WebM + ffmpeg-derived MP4/GIF
apps/e2e/demo-results/
apps/e2e/src/demo/out/

# fallow metrics output (regenerated by `pnpm metrics`)
.metrics/

# WXT-managed persistent dev profiles (created by `dev:firefox:installed` /
# `dev:chrome:installed`) — toolbar pin and storage survive across runs.
.firefox-profile/
.chromium-profile/

# wrangler local state (Cloudflare Pages dev / build cache for apps/marketing)
.wrangler/

# sandbox scratch files
__link.txt
__probe.txt
_tmp_*

# Xcode build state for the Safari wrapper (apps/extension/safari/Movar.xcodeproj).
# The .xcodeproj itself is committed; per-user state and build outputs are not.
**/xcuserdata/
**/*.xcuserstate
apps/extension/safari/**/build/
apps/extension/safari/**/DerivedData/
apps/extension/safari/**/.swiftpm/

# Safari extension Resources are synced from `.output/safari-mv3/` by
# apps/extension/scripts/sync-safari-resources.mts on every Safari build.
# Xcode picks them up via folder references in project.pbxproj — no need to track.
apps/extension/safari/Movar/Shared (Extension)/Resources/

# Host-app shared-logic bundle, generated from `@movar/lang-detect` +
# `@movar/settings` by apps/extension/scripts/build-app-bundle.mts on every
# Safari build (folded into `build:safari`, which every xcodebuild path runs
# first). Referenced per-file in project.pbxproj like the rest of the host
# bundle, but never hand-edited — regenerated, not tracked.
apps/extension/safari/Movar/Shared (App)/Resources/movar-app.js
