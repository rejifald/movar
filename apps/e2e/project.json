{
  "name": "e2e",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "projectType": "application",
  "sourceRoot": "apps/e2e/src",
  "targets": {
    "typecheck": {
      "executor": "nx:run-commands",
      "options": { "command": "tsc --noEmit", "cwd": "apps/e2e" },
      "cache": true
    },
    "lint": {
      "executor": "nx:run-commands",
      "options": {
        "command": "eslint . --cache --cache-location node_modules/.eslintcache",
        "cwd": "apps/e2e"
      },
      "cache": true
    },
    "test": {
      "executor": "nx:run-commands",
      "options": { "command": "playwright test", "cwd": "apps/e2e" },
      "dependsOn": [
        { "projects": ["extension"], "target": "build:e2e" },
        { "projects": ["safari-host-app"], "target": "build" },
        { "projects": ["diagnostics"], "target": "build:harness" }
      ]
    },
    "test:fg": {
      "executor": "nx:run-commands",
      "options": { "command": "playwright test --headed", "cwd": "apps/e2e" },
      "dependsOn": [{ "projects": ["extension"], "target": "build:e2e" }]
    },
    "test:ui": {
      "executor": "nx:run-commands",
      "options": { "command": "playwright test --ui", "cwd": "apps/e2e" },
      "dependsOn": [{ "projects": ["extension"], "target": "build:e2e" }]
    },
    "test:update": {
      "executor": "nx:run-commands",
      "options": { "command": "playwright test --update-snapshots=all", "cwd": "apps/e2e" },
      "dependsOn": [
        { "projects": ["extension"], "target": "build:e2e" },
        { "projects": ["safari-host-app"], "target": "build" },
        { "projects": ["diagnostics"], "target": "build:harness" }
      ]
    },
    "test:popup": {
      "executor": "nx:run-commands",
      "options": { "command": "playwright test --grep popup", "cwd": "apps/e2e" },
      "dependsOn": [{ "projects": ["extension"], "target": "build:e2e" }]
    },
    "test:fast": {
      "executor": "nx:run-commands",
      "options": {
        "command": "playwright test popup.spec.ts popup.behavior.spec.ts options.spec.ts options.behavior.spec.ts",
        "cwd": "apps/e2e"
      },
      "dependsOn": [{ "projects": ["extension"], "target": "build:e2e" }]
    },
    "test:live": {
      "executor": "nx:run-commands",
      "options": {
        "command": "playwright test --config playwright.live.config.ts",
        "cwd": "apps/e2e"
      },
      "dependsOn": [{ "projects": ["extension"], "target": "build:e2e" }]
    },
    "test:live:headed": {
      "executor": "nx:run-commands",
      "options": {
        "command": "playwright test --config playwright.live.config.ts --headed",
        "cwd": "apps/e2e"
      },
      "dependsOn": [{ "projects": ["extension"], "target": "build:e2e" }]
    },
    "test:marketing": {
      "executor": "nx:run-commands",
      "options": {
        "command": "playwright test --config playwright.marketing.config.ts",
        "cwd": "apps/e2e"
      },
      "dependsOn": [{ "projects": ["marketing"], "target": "build" }]
    },
    "test:marketing:update": {
      "executor": "nx:run-commands",
      "options": {
        "command": "playwright test --config playwright.marketing.config.ts --update-snapshots=all",
        "cwd": "apps/e2e"
      },
      "dependsOn": [{ "projects": ["marketing"], "target": "build" }]
    }
  }
}
