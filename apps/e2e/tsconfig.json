{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "types": ["node", "chrome"],
    "noEmit": true,
    "moduleResolution": "Bundler",
    "resolveJsonModule": true
  },
  "include": [
    "src",
    "playwright.config.ts",
    "playwright.live.config.ts",
    "playwright.demo.config.ts"
  ],
  "exclude": ["node_modules", "test-results", "playwright-report"]
}
