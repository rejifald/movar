{
  "name": "@movar/extension",
  "version": "1.2.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "wxt",
    "dev:chrome:installed": "MOVAR_CHROMIUM_PERSIST=1 wxt",
    "dev:firefox": "wxt -b firefox",
    "dev:firefox:installed": "MOVAR_FIREFOX_PERSIST=1 wxt -b firefox",
    "dev:safari": "tsx scripts/watch-safari-build.mts",
    "build": "wxt build && wxt build -b firefox && pnpm build:safari",
    "build:chrome": "wxt build",
    "build:firefox": "wxt build -b firefox",
    "build:safari": "wxt build -b safari && tsx scripts/sync-safari-resources.mts",
    "build:e2e": "MOVAR_E2E=1 wxt build",
    "build:safari:app": "tsx scripts/build-safari-app.mts",
    "sync:safari": "tsx scripts/sync-safari-resources.mts",
    "zip": "wxt zip",
    "zip:firefox": "wxt zip -b firefox",
    "zip:safari": "wxt zip -b safari",
    "preview:build": "MOVAR_PREVIEW=1 wxt build",
    "preview:popup": "pnpm preview:build && pnpm dlx serve -l 4322 --no-clipboard .output/chrome-mv3",
    "preview:options": "pnpm preview:build && pnpm dlx serve -l 4323 --no-clipboard .output/chrome-mv3",
    "storybook": "storybook dev -p 6008 --no-open",
    "build-storybook": "storybook build -o storybook-static",
    "capture:storybook-assets": "tsx scripts/capture-storybook-assets.mts",
    "screenshots": "pnpm build-storybook && pnpm capture:storybook-assets",
    "icons": "tsx scripts/generate-icons.mts",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "test": "vitest run",
    "check:content-bundle": "tsx scripts/check-content-bundle.mts",
    "postinstall": "wxt prepare"
  },
  "dependencies": {
    "@fontsource/ibm-plex-mono": "^5.2.7",
    "@fontsource/manrope": "^5.2.7",
    "@movar/app-shell": "workspace:*",
    "@movar/brand": "workspace:*",
    "@movar/events": "workspace:*",
    "@movar/lang-detect": "workspace:*",
    "@movar/lang-pickers": "workspace:*",
    "@movar/page-content": "workspace:*",
    "@movar/page-language": "workspace:*",
    "@movar/page-mode": "workspace:*",
    "@movar/host-match": "workspace:*",
    "@movar/i18n": "workspace:*",
    "@movar/options-ui": "workspace:*",
    "@movar/settings": "workspace:*",
    "@movar/ui": "workspace:*",
    "lucide": "^1.17.0",
    "lucide-react": "^1.17.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6"
  },
  "devDependencies": {
    "@movar/eslint-config": "workspace:*",
    "@storybook/addon-docs": "^10.4.1",
    "@storybook/react": "^10.4.1",
    "@storybook/react-vite": "^10.4.1",
    "@tailwindcss/vite": "^4.3.0",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/chrome": "^0.1.42",
    "@types/node": "^25.9.1",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "@wxt-dev/module-react": "^1.2.2",
    "esbuild": "^0.27.7",
    "eslint": "^9.39.4",
    "playwright": "^1.49.1",
    "sharp": "^0.34.4",
    "storybook": "^10.4.1",
    "tailwindcss": "^4.3.0",
    "tsx": "^4.22.3",
    "vite": "^7.3.3",
    "wxt": "^0.20.26"
  }
}
