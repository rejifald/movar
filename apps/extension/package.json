{
  "name": "@movar/extension",
  "version": "1.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "wxt",
    "dev:chrome:installed": "MOVAR_CHROMIUM_PERSIST=1 wxt",
    "dev:firefox": "wxt -b firefox",
    "dev:firefox:installed": "MOVAR_FIREFOX_PERSIST=1 wxt -b firefox",
    "dev:safari": "tsx scripts/watch-safari-build.mts",
    "build": "wxt build && wxt build -b firefox && pnpm build:safari",
    "build:chrome": "wxt build",
    "build:firefox": "wxt build -b firefox",
    "build:safari": "wxt build -b safari && tsx scripts/sync-safari-resources.mts",
    "sync:safari": "tsx scripts/sync-safari-resources.mts",
    "zip": "wxt zip",
    "zip:firefox": "wxt zip -b firefox",
    "zip:safari": "wxt zip -b safari",
    "preview:build": "MOVAR_PREVIEW=1 wxt build",
    "preview:popup": "pnpm preview:build && pnpm dlx serve -l 4322 --no-clipboard .output/chrome-mv3",
    "preview:options": "pnpm preview:build && pnpm dlx serve -l 4323 --no-clipboard .output/chrome-mv3",
    "storybook": "storybook dev -p 6008 --no-open",
    "build-storybook": "storybook build -o storybook-static",
    "capture:storybook-assets": "tsx scripts/capture-storybook-assets.mts",
    "icons": "tsx scripts/generate-icons.mts",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "test": "vitest run",
    "postinstall": "wxt prepare"
  },
  "dependencies": {
    "@fontsource/ibm-plex-mono": "^5.2.7",
    "@fontsource/manrope": "^5.2.7",
    "@movar/lang-detect": "workspace:*",
    "@movar/rules": "workspace:*",
    "@movar/shared": "workspace:*",
    "@movar/ui": "workspace:*",
    "react": "^19.2.6",
    "react-dom": "^19.2.6"
  },
  "devDependencies": {
    "@movar/eslint-config": "workspace:*",
    "@storybook/addon-docs": "^10.4.1",
    "@storybook/react": "^10.4.1",
    "@storybook/react-vite": "^10.4.1",
    "@tailwindcss/vite": "^4.3.0",
    "@types/chrome": "^0.1.42",
    "@types/node": "^25.9.1",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "@wxt-dev/module-react": "^1.2.2",
    "addons-linter": "^7.16.0",
    "esbuild": "^0.27.7",
    "eslint": "^9.39.4",
    "playwright": "^1.49.1",
    "sharp": "^0.34.4",
    "storybook": "^10.4.1",
    "tailwindcss": "^4.3.0",
    "tsx": "^4.22.3",
    "wxt": "^0.20.26"
  }
}
