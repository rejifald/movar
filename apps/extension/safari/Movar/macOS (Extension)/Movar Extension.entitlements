<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<!-- Sandbox/hardened-runtime stay owned by the ENABLE_* build settings and
	     merge in at sign time; this file carries only the shared App Group. -->
	<key>com.apple.security.application-groups</key>
	<array>
		<string>group.fyi.movar.safari</string>
	</array>
</dict>
</plist>
