---
/**
 * Side-by-side before/after for a single representative search.
 *
 * Drop the two PNGs at:
 *   apps/marketing/public/screenshots/google-without-movar.png
 *   apps/marketing/public/screenshots/google-with-movar.png
 *
 * Both 1280×800 (16:10). Until both files exist the section is silently
 * omitted from the page — no placeholder cards, no broken images.
 */

import { existsSync } from 'node:fs';
import { fileURLToPath } from 'node:url';
import path from 'node:path';
import { strings, type Locale } from '../i18n';

interface Props {
  lang?: Locale;
}

const { lang = 'en' } = Astro.props;
const t = strings[lang].beforeAfter;

// resolve public/screenshots relative to this component file
const publicDir = path.resolve(path.dirname(fileURLToPath(import.meta.url)), '../../public');
const hasImages =
  existsSync(path.join(publicDir, 'screenshots/google-without-movar.png')) &&
  existsSync(path.join(publicDir, 'screenshots/google-with-movar.png'));

interface Comparison {
  label: string;
  variant: 'without' | 'with';
  caption: string;
  src: string;
  alt: string;
}

const comparisons: Comparison[] = [
  {
    label: t.without,
    variant: 'without',
    caption: t.withoutCaption,
    src: '/screenshots/google-without-movar.png',
    alt: 'Google search results for a Cyrillic query, with Russian-language pages dominating',
  },
  {
    label: t.withMovar,
    variant: 'with',
    caption: t.withCaption,
    src: '/screenshots/google-with-movar.png',
    alt: 'Same Google search, now returning Ukrainian-language pages',
  },
];
---

{hasImages && (
  <section id="before-after" class="border-t border-border bg-surface px-6 py-20">
    <div class="mx-auto max-w-5xl">
      <h2 class="font-display text-3xl font-extrabold tracking-tight text-ink-strong sm:text-4xl">
        {t.sectionTitle}
      </h2>
      <p class="mt-3 max-w-2xl text-ink-soft">
        {t.sectionLead}
      </p>

      <div class="mt-10 grid gap-6 sm:grid-cols-2">
        {
          comparisons.map((c) => (
            <figure
              class:list={[
                'rounded-2xl border bg-bg p-3 shadow-sm',
                c.variant === 'with' ? 'border-accent/30' : 'border-border',
              ]}
            >
              <div class="relative flex aspect-[16/10] items-center justify-center overflow-hidden rounded-lg">
                <img
                  src={c.src}
                  alt={c.alt}
                  loading="lazy"
                  class="size-full object-cover"
                />
              </div>
              <figcaption class="mt-3 px-1 pb-1">
                <div
                  class:list={[
                    'font-mono text-xs tracking-[0.1em] uppercase',
                    c.variant === 'with' ? 'text-accent' : 'text-ink-faint',
                  ]}
                >
                  {c.label}
                </div>
                <p class="text-ink mt-1 text-sm">{c.caption}</p>
              </figcaption>
            </figure>
          ))
        }
      </div>
    </div>
  </section>
)}
