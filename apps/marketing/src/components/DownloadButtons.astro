---
/*
 * Single install CTA. The visitor doesn't pick a store — we detect their
 * browser and point the button at the matching marketplace, with a
 * GitHub-releases fallback so unrecognised browsers still have a target.
 *
 * The button is always enabled (never greyed out). Per-browser states the
 * script lands on:
 * - Detected browser, store live      → enabled link to the store.
 * - Detected browser, store not live  → enabled but inert (no href + no-op
 *                                        click), with a "Soon" chip so the
 *                                        visitor knows the listing is pending.
 * - Unrecognised browser              → enabled link to GitHub releases.
 *
 * SSR renders the neutral "Add Movar to your browser" label with the GitHub
 * href so no-JS visitors get a working destination; the inline script swaps
 * in the per-browser label + target once it detects the browser.
 *
 * Store config + browser detection live in ../lib/downloads so this CTA and
 * the header's Download nav link resolve to the same targets.
 *
 * Opera and Brave install Chromium extensions via the Chrome Web Store but
 * keep their own button label. Safari needs its own WebExtension build.
 */

import { FALLBACK_HREF, perBrowser } from '../lib/downloads';
import { browserIconPaths, githubIconPath } from '../lib/browser-icons';
import { strings, type Locale } from '../i18n';

interface Props {
  lang?: Locale;
}

const { lang = 'en' } = Astro.props;
const t = strings[lang].download;
---

<div id="download" class="flex justify-center">
  <a
    data-cta
    data-stores={JSON.stringify(perBrowser)}
    data-labels={JSON.stringify(t.add)}
    data-icons={JSON.stringify(browserIconPaths)}
    data-github-icon={githubIconPath}
    data-soon-label={t.soon}
    data-fallback-label={t.viaGithub}
    href={FALLBACK_HREF}
    class="group inline-flex cursor-pointer items-center justify-center gap-2 rounded-xl border border-accent bg-accent px-6 py-3 text-sm font-semibold text-accent-on shadow-sm transition hover:shadow-md"
  >
    <span data-cta-label>{t.addGeneric}</span>
  </a>
</div>

<script>
  import { detectBrowser, type BrowserId } from '../lib/downloads';

  const cta = document.querySelector<HTMLAnchorElement>('[data-cta]');
  if (cta) {
    const id = detectBrowser();

    const stores = JSON.parse(cta.dataset['stores'] ?? '{}') as Record<
      BrowserId,
      { href: string; liveAt: string | null }
    >;
    const labels = JSON.parse(cta.dataset['labels'] ?? '{}') as Record<BrowserId, string>;
    const icons = JSON.parse(cta.dataset['icons'] ?? '{}') as Record<BrowserId, string>;
    const githubIcon = cta.dataset['githubIcon'] ?? '';
    const soonLabel = cta.dataset['soonLabel'] ?? '';
    const fallbackLabel = cta.dataset['fallbackLabel'] ?? '';
    const labelEl = cta.querySelector<HTMLSpanElement>('[data-cta-label]');

    // Prepend a logo before the label. Built here (not in SSR) so the no-JS /
    // neutral state has no leading icon — gap-2 only kicks in once this sized
    // element exists, avoiding a stray gap before the text.
    const prependIcon = (path: string) => {
      if (!path || !labelEl) return;
      const icon = document.createElement('span');
      icon.setAttribute('aria-hidden', 'true');
      icon.className = 'inline-flex shrink-0';
      icon.innerHTML = `<svg viewBox="0 0 24 24" fill="currentColor" class="h-4 w-4"><path d="${path}"/></svg>`;
      labelEl.before(icon);
    };

    if (!id) {
      // Unrecognised browser — keep the SSR GitHub href, refresh the label and
      // mark it with the GitHub logo to match "Get Movar from GitHub".
      if (labelEl) labelEl.textContent = fallbackLabel;
      prependIcon(githubIcon);
    } else {
      // Matching browser glyph so the button reads "[Chrome] Add to Chrome".
      if (labelEl) labelEl.textContent = labels[id];
      prependIcon(icons[id]);
      const store = stores[id];
      if (store?.liveAt) {
        cta.href = store.href;
      } else {
        // Listing isn't live yet — drop the href so the click is a no-op, but
        // keep the button visually enabled and add a "Soon" chip so visitors
        // know it's coming. Tinted with bg-black/25 (not bg-accent-deep) so
        // the chip stays a darker patch on the green button in both themes.
        cta.removeAttribute('href');
        if (labelEl) {
          const span = document.createElement('span');
          span.dataset['ctaSoon'] = '';
          span.className =
            'rounded-md bg-black/25 px-1.5 py-0.5 text-[11px] font-medium uppercase tracking-wide text-accent-on';
          span.textContent = soonLabel;
          labelEl.after(span);
        }
      }
    }
  }
</script>
