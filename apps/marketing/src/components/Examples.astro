---
/**
 * "Приклади" — concrete before/after examples in an open, card-less
 * layout: a site eyebrow + scenario, then a without/with breakdown.
 * Entries with a captured screenshot pair (keyed by index below) render
 * the visuals; the rest fall back to the text-only breakdown. Pairs are
 * gated by existsSync, so a half-finished capture run degrades instead of
 * shipping broken images. Screenshots are shared with the extension store
 * assets via the screenshot pipeline.
 */

import { existsSync } from 'node:fs';
import { fileURLToPath } from 'node:url';
import path from 'node:path';
import { strings, type Locale } from '../i18n';

interface Props {
  lang?: Locale;
}

const { lang = 'en' } = Astro.props;
const t = strings[lang].examples;

const publicDir = path.resolve(path.dirname(fileURLToPath(import.meta.url)), '../../public');

interface ExampleImage {
  src: string;
  alt: string;
}
interface ExampleImagePair {
  without: ExampleImage;
  with: ExampleImage;
}

// Screenshot pairs keyed by entry index. Only entries listed here — and
// only when both light PNGs are on disk — render visuals; the rest stay
// text-only. The dark sibling (`…-dark.png`) is added automatically when
// present, and swapped in via <picture> + prefers-color-scheme so the
// shots track the page theme.
const imagePairs: Record<number, ExampleImagePair> = {
  0: {
    without: {
      src: '/screenshots/google-without-movar.png',
      alt: 'Google search results for a Cyrillic query, with Russian-language pages dominating',
    },
    with: {
      src: '/screenshots/google-with-movar.png',
      alt: 'Same Google search, now returning Ukrainian-language pages',
    },
  },
  1: {
    without: {
      src: '/screenshots/google-god-of-war-without-movar.png',
      alt: 'Google search for "God of War" with the summary card on the right rendered in English',
    },
    with: {
      src: '/screenshots/google-god-of-war-with-movar.png',
      alt: 'Same Google search, summary card now rendered in Ukrainian',
    },
  },
  2: {
    without: {
      src: '/screenshots/youtube-without-movar.png',
      alt: 'YouTube results for a Ukrainian-language query, recommendations dominated by Russian-language channels',
    },
    with: {
      src: '/screenshots/youtube-with-movar.png',
      alt: 'Same YouTube search, now recommending Ukrainian creators',
    },
  },
  3: {
    without: {
      src: '/screenshots/shop-without-movar.png',
      alt: 'A Ukrainian online shop product page opened in Russian by default',
    },
    with: {
      src: '/screenshots/shop-with-movar.png',
      alt: 'The same shop product page showing its Ukrainian version',
    },
  },
};

const onDisk = (src: string): boolean =>
  existsSync(path.join(publicDir, src.replace(/^\//, '')));

const darkSrc = (src: string): string => src.replace(/\.png$/, '-dark.png');

interface ResolvedImage extends ExampleImage {
  /** Dark-theme sibling, present only when the `-dark` PNG is on disk. */
  dark?: string;
}
interface ResolvedPair {
  without: ResolvedImage;
  with: ResolvedImage;
}

const resolveImage = (img: ExampleImage): ResolvedImage => {
  const dark = darkSrc(img.src);
  return onDisk(dark) ? { ...img, dark } : { ...img };
};

const imagesFor = (i: number): ResolvedPair | null => {
  const pair = imagePairs[i];
  if (!pair || !onDisk(pair.without.src) || !onDisk(pair.with.src)) return null;
  return { without: resolveImage(pair.without), with: resolveImage(pair.with) };
};

const chipBase =
  'inline-flex items-center rounded-full px-2.5 py-1 font-mono text-ui-xs font-semibold uppercase tracking-wider';
---

<section id="examples" class="border-t border-border bg-bg px-6 py-20">
  <div class="mx-auto max-w-5xl">
    <h2 class="font-display text-3xl font-extrabold tracking-tight text-ink-strong sm:text-4xl">
      {t.sectionTitle}
    </h2>
    <p class="mt-3 max-w-2xl text-ink-soft">
      {t.sectionLead}
    </p>

    <div class="mt-12 divide-y divide-border">
      {
        t.entries.map((example, i) => {
          const images = imagesFor(i);
          return (
            <article class="py-12 first:pt-0">
              <p class="font-display text-xs font-bold uppercase tracking-wider text-accent">
                {example.site}
              </p>
              <h3 class="mt-2 max-w-2xl text-lg font-medium leading-snug text-ink-strong sm:text-xl">
                {example.scenario}
              </h3>

              <div class="mt-6 grid items-start gap-x-8 gap-y-8 sm:grid-cols-2">
                <figure>
                  <span class:list={[chipBase, 'border border-border bg-surface text-ink-soft']}>
                    {t.without}
                  </span>
                  {images && (
                    <div class="mt-3 overflow-hidden rounded-lg border border-border">
                      <picture>
                        {images.without.dark && (
                          <source srcset={images.without.dark} media="(prefers-color-scheme: dark)" />
                        )}
                        <img
                          src={images.without.src}
                          alt={images.without.alt}
                          loading="lazy"
                          class="block h-auto w-full"
                        />
                      </picture>
                    </div>
                  )}
                  <p class="mt-3 text-sm leading-relaxed text-ink-soft">{example.without}</p>
                </figure>

                <figure>
                  <span class:list={[chipBase, 'border border-accent/30 bg-accent-surface text-accent-deep']}>
                    <span aria-hidden="true" class="mr-1 text-[1.35em] font-bold leading-none">✓</span>
                    {t.withMovar}
                  </span>
                  {images && (
                    <div class="mt-3 overflow-hidden rounded-lg border border-accent/40">
                      <picture>
                        {images.with.dark && (
                          <source srcset={images.with.dark} media="(prefers-color-scheme: dark)" />
                        )}
                        <img
                          src={images.with.src}
                          alt={images.with.alt}
                          loading="lazy"
                          class="block h-auto w-full"
                        />
                      </picture>
                    </div>
                  )}
                  <p class="mt-3 text-sm leading-relaxed text-ink-soft">{example.withMovar}</p>
                </figure>
              </div>
            </article>
          );
        })
      }
    </div>
  </div>
</section>
