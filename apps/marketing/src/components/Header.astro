---
import { FEEDBACK_URL } from '@movar/brand';
import { Menu, X } from 'lucide-astro';
import { FALLBACK_HREF } from '../lib/downloads';
import { localeHomeHref, localePrivacyHref, strings, type Locale } from '../i18n';

interface Props {
  lang?: Locale;
}

// Locale is intentionally not user-switchable from the UI — the visitor's
// Accept-Language header is the source of truth, applied at the edge by
// functions/_middleware.ts. Anyone who needs the alternate locale can use
// their browser's language preference or type the /uk/ path directly.
const { lang = 'en' } = Astro.props;
const t = strings[lang];
const home = localeHomeHref(lang);
const privacy = localePrivacyHref(lang);

// The same three links render in the desktop row and the mobile menu — each is
// an action or off-page destination (no in-page section jumps; the page is a
// scroll-first narrative). `download` flags the install link, which the script
// below resolves to a browser-detected store, mirroring the hero CTA.
const links = [
  { href: FALLBACK_HREF, label: t.nav.download, download: true },
  { href: FEEDBACK_URL, label: t.nav.feedback, download: false },
  { href: privacy, label: t.nav.privacy, download: false },
];
---

<header
  class="sticky top-0 z-50 border-b border-border/60 bg-bg/85 backdrop-blur supports-[backdrop-filter]:bg-bg/70"
>
  <div class="mx-auto flex max-w-5xl items-center justify-between px-6 py-4">
    <a href={home} class="flex items-center gap-2.5 font-display font-bold text-ink-strong">
      <img src="/icon.svg" alt="" width="28" height="28" class="rounded-md" />
      <span class="text-lg tracking-tight">movar<span class="text-accent">.fyi</span></span>
    </a>

    {/*
     * Desktop: links inline. The three Ukrainian labels are too wide for a
     * phone row, so below sm: they collapse into the hamburger menu.
     */}
    <nav class="hidden items-center gap-x-5 text-sm text-ink-soft sm:flex">
      {
        links.map((link) => (
          <a
            href={link.href}
            data-download-cta={link.download ? '' : undefined}
            data-soon-label={link.download ? t.download.soon : undefined}
            class="inline-flex items-center gap-1.5 transition hover:text-ink-strong"
          >
            {link.label}
          </a>
        ))
      }
    </nav>

    <button
      type="button"
      data-menu-toggle
      aria-label={t.nav.menu}
      aria-controls="mobile-menu"
      aria-expanded="false"
      class="-mr-2 inline-flex items-center justify-center rounded-md p-2 text-ink-soft transition hover:text-ink-strong sm:hidden"
    >
      <Menu data-menu-icon-open class="size-6" />
      <X data-menu-icon-close class="hidden size-6" />
    </button>
  </div>

  {/* Mobile menu — toggled by the hamburger, never shown at sm+. */}
  <nav id="mobile-menu" data-menu-panel class="hidden border-t border-border/60 sm:hidden">
    <ul class="mx-auto flex max-w-5xl flex-col px-4 py-2 text-sm text-ink-soft">
      {
        links.map((link) => (
          <li>
            <a
              href={link.href}
              data-download-cta={link.download ? '' : undefined}
              data-soon-label={link.download ? t.download.soon : undefined}
              class="flex items-center gap-1.5 rounded-lg px-2 py-3 transition hover:bg-surface hover:text-ink-strong"
            >
              {link.label}
            </a>
          </li>
        ))
      }
    </ul>
  </nav>
</header>

<script>
  import { detectBrowser, perBrowser } from '../lib/downloads';
  import { browserIconPaths, githubIconPath } from '../lib/browser-icons';

  // Mark the link's label with a logo, mirroring the hero CTA. Built client-side
  // so the no-JS state stays text-only — the link's gap-1.5 only spaces real
  // elements, so there's no stray leading gap before the text until JS adds the
  // glyph. Prepended (not appended) so it reads "[Chrome] Download".
  const prependIcon = (link: HTMLAnchorElement, path: string) => {
    if (!path) return;
    const icon = document.createElement('span');
    icon.setAttribute('aria-hidden', 'true');
    icon.className = 'inline-flex shrink-0';
    icon.innerHTML = `<svg viewBox="0 0 24 24" fill="currentColor" class="h-4 w-4"><path d="${path}"/></svg>`;
    link.prepend(icon);
  };

  // Download mirrors the hero CTA wherever it renders (desktop row + mobile
  // menu): same browser detection, same store target, same inert + "Soon"
  // state when the listing is pending. SSR left the GitHub fallback href in
  // place for unrecognised browsers / no JS.
  const id = detectBrowser();
  for (const link of document.querySelectorAll<HTMLAnchorElement>('[data-download-cta]')) {
    if (!id) {
      // Unrecognised browser — keep the SSR GitHub fallback href and mark it
      // with the GitHub logo, matching the hero CTA's fallback.
      prependIcon(link, githubIconPath);
      continue;
    }
    prependIcon(link, browserIconPaths[id]);
    const store = perBrowser[id];
    if (store.liveAt) {
      link.href = store.href;
    } else {
      // Listing isn't live yet — drop the href so the click is a no-op and
      // flag it "Soon", exactly like the hero CTA.
      link.removeAttribute('href');
      const soonLabel = link.dataset['soonLabel'];
      if (soonLabel) {
        const chip = document.createElement('span');
        chip.className =
          'rounded bg-accent-surface px-1.5 py-0.5 text-[10px] font-semibold uppercase tracking-wide text-accent';
        chip.textContent = soonLabel;
        link.append(chip);
      }
    }
  }

  // Hamburger toggle for the mobile menu.
  const toggle = document.querySelector<HTMLButtonElement>('[data-menu-toggle]');
  const panel = document.querySelector<HTMLElement>('[data-menu-panel]');
  if (toggle && panel) {
    const openIcon = toggle.querySelector('[data-menu-icon-open]');
    const closeIcon = toggle.querySelector('[data-menu-icon-close]');
    const setOpen = (open: boolean) => {
      toggle.setAttribute('aria-expanded', String(open));
      panel.classList.toggle('hidden', !open);
      openIcon?.classList.toggle('hidden', open);
      closeIcon?.classList.toggle('hidden', !open);
    };

    toggle.addEventListener('click', () => {
      setOpen(toggle.getAttribute('aria-expanded') !== 'true');
    });
    // Close after picking a link, on Escape, on tap outside the header, or once
    // the viewport grows past sm: (where the menu is hidden anyway).
    panel.addEventListener('click', (event) => {
      if ((event.target as HTMLElement).closest('a')) setOpen(false);
    });
    document.addEventListener('keydown', (event) => {
      if (event.key === 'Escape') setOpen(false);
    });
    document.addEventListener('click', (event) => {
      if (!(event.target as HTMLElement).closest('header') && toggle.getAttribute('aria-expanded') === 'true') {
        setOpen(false);
      }
    });
    window.matchMedia('(min-width: 640px)').addEventListener('change', (event) => {
      if (event.matches) setOpen(false);
    });
  }
</script>
