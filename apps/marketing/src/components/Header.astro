---
import { FEEDBACK_URL } from '@movar/shared';
import { FALLBACK_HREF } from '../lib/downloads';
import { localeHomeHref, localePrivacyHref, strings, type Locale } from '../i18n';

interface Props {
  lang?: Locale;
}

// Locale is intentionally not user-switchable from the UI — the visitor's
// Accept-Language header is the source of truth, applied at the edge by
// functions/_middleware.ts. Anyone who needs the alternate locale can use
// their browser's language preference or type the /uk/ path directly.
const { lang = 'en' } = Astro.props;
const t = strings[lang];
const home = localeHomeHref(lang);
const privacy = localePrivacyHref(lang);
---

<header
  class="sticky top-0 z-50 border-b border-border/60 bg-bg/85 backdrop-blur supports-[backdrop-filter]:bg-bg/70"
>
  <div class="mx-auto flex max-w-5xl items-center justify-between px-6 py-4">
    <a href={home} class="flex items-center gap-2.5 font-display font-bold text-ink-strong">
      <img src="/icon.svg" alt="" width="28" height="28" class="rounded-md" />
      <span class="text-lg tracking-tight">movar<span class="text-accent">.fyi</span></span>
    </a>
    {/*
     * The page is a single scroll-first narrative, so the nav skips in-page
     * section jumps (you scroll to read it) and carries only the three links
     * that are an action or an off-page destination: Download, Contact, and
     * Privacy. The labels are short enough that all three fit at every width —
     * no responsive hiding, no hamburger.
     *
     * Download mirrors the hero CTA: the script below resolves it to the same
     * browser-detected store (or the GitHub fallback for unrecognised
     * browsers), and lands on the same inert + "Soon" state when that store
     * isn't live yet. SSR renders the GitHub fallback so no-JS visitors still
     * get a working destination.
     */}
    <nav class="flex items-center gap-x-4 text-sm text-ink-soft sm:gap-x-5">
      <a
        data-download-cta
        data-soon-label={t.download.soon}
        href={FALLBACK_HREF}
        class="inline-flex items-center gap-1.5 hover:text-ink-strong transition"
      >
        {t.nav.download}
      </a>
      <a href={FEEDBACK_URL} class="hover:text-ink-strong transition">{t.nav.feedback}</a>
      <a href={privacy} class="hover:text-ink-strong transition">{t.nav.privacy}</a>
    </nav>
  </div>
</header>

<script>
  import { detectBrowser, perBrowser } from '../lib/downloads';

  // Mirror the hero CTA on the Download nav link: same browser detection, same
  // store target, same inert + "Soon" state when the listing is pending. SSR
  // left the GitHub fallback href in place for unrecognised browsers / no JS.
  const link = document.querySelector<HTMLAnchorElement>('[data-download-cta]');
  if (link) {
    const id = detectBrowser();
    if (id) {
      const store = perBrowser[id];
      if (store.liveAt) {
        link.href = store.href;
      } else {
        // Listing isn't live yet — drop the href so the click is a no-op and
        // flag it "Soon", exactly like the hero CTA.
        link.removeAttribute('href');
        const soonLabel = link.dataset['soonLabel'];
        if (soonLabel) {
          const chip = document.createElement('span');
          // Desktop-only: the chip is the widest thing in the nav, and the
          // Ukrainian "Незабаром" would push the row past a phone's width.
          // Below sm: the link is just "Download" (still inert when pending).
          chip.className =
            'hidden rounded bg-accent-surface px-1.5 py-0.5 text-[10px] font-semibold uppercase tracking-wide text-accent sm:inline';
          chip.textContent = soonLabel;
          link.append(chip);
        }
      }
    }
  }
</script>
