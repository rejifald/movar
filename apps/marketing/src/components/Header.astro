---
import { localeHomeHref, localePrivacyHref, strings, type Locale } from '../i18n';

interface Props {
  lang?: Locale;
}

const { lang = 'en' } = Astro.props;
const t = strings[lang];
const home = localeHomeHref(lang);
const privacy = localePrivacyHref(lang);
---

<header
  class="sticky top-0 z-50 border-b border-border/60 bg-bg/85 backdrop-blur supports-[backdrop-filter]:bg-bg/70"
>
  <div class="mx-auto flex max-w-5xl items-center justify-between px-6 py-4">
    <a href={home} class="flex items-center gap-2.5 font-display font-bold text-ink-strong">
      <img src="/icon.svg" alt="" width="28" height="28" class="rounded-md" />
      <span class="text-lg tracking-tight">movar<span class="text-accent">.fyi</span></span>
    </a>
    {/*
     * Mobile is scroll-first — every section is a top-to-bottom narrative,
     * so the in-page jump links don't earn their cost on a 375px header,
     * where the previous flex-wrap put "Download" right on top of the
     * logo. Below sm:, the jump links collapse to just Download (the only
     * action) + Privacy (off-page). Anything richer (hamburger drawer) is
     * a follow-up if it ever earns its weight.
     */}
    <nav class="flex items-center gap-x-5 text-sm text-ink-soft">
      <a
        href={`${home}#how-it-works`}
        class="hidden sm:inline hover:text-ink-strong transition"
      >
        {t.nav.howItWorks}
      </a>
      <a
        href={`${home}#examples`}
        class="hidden sm:inline hover:text-ink-strong transition"
      >
        {t.nav.examples}
      </a>
      <a
        href={`${home}#limitations`}
        class="hidden sm:inline hover:text-ink-strong transition"
      >
        {t.nav.limitations}
      </a>
      <a href={`${home}#download`} class="hover:text-ink-strong transition">
        {t.nav.download}
      </a>
      <a href={privacy} class="hover:text-ink-strong transition">{t.nav.privacy}</a>
    </nav>
  </div>
</header>
