---
import { Tag, CodeXml, ShieldCheck } from 'lucide-astro';

import DownloadButtons from './DownloadButtons.astro';
import { strings, type Locale } from '../i18n';

interface Props {
  lang?: Locale;
}

const { lang = 'en' } = Astro.props;
const t = strings[lang].hero;

// Each trust claim carries its own icon so every mark means something
// (the old single dot read like a status indicator). ShieldCheck echoes
// the Privacy section's shield; Tag = free, CodeXml = open source.
const claims = [
  { label: t.badge.free, Icon: Tag },
  { label: t.badge.openSource, Icon: CodeXml },
  { label: t.badge.privacy, Icon: ShieldCheck },
];
---

<section class="relative overflow-hidden px-6 pt-20 pb-16 sm:pt-28 sm:pb-24">
  <div class="hero-backdrop" aria-hidden="true">
    <span class="hero-backdrop__aurora hero-backdrop__aurora--1"></span>
    <span class="hero-backdrop__aurora hero-backdrop__aurora--2"></span>
    <span class="hero-backdrop__glow"></span>
    <span class="hero-backdrop__grid"></span>
  </div>

  <div class="relative z-10 mx-auto max-w-3xl text-center">
    <div
      class="mb-6 inline-flex max-w-full flex-wrap items-center justify-center gap-x-3 gap-y-1.5 rounded-full border border-border bg-surface px-4 py-1.5 text-xs font-medium text-ink-soft shadow-sm"
    >
      {
        claims.map(({ label, Icon }) => (
          <span class="inline-flex items-center gap-1.5 whitespace-nowrap">
            <Icon class="size-3.5 shrink-0 text-accent" aria-hidden="true" />
            {label}
          </span>
        ))
      }
    </div>

    <h1
      class="font-display text-5xl font-extrabold tracking-tight text-ink-strong sm:text-6xl"
    >
      {t.headlineLine1}
      <span class="block text-accent">{t.headlineLine2}</span>
    </h1>

    <p class="mx-auto mt-6 max-w-2xl text-lg text-ink-soft sm:text-xl">
      {t.subhead}
    </p>

    <div class="mt-10">
      <DownloadButtons lang={lang} />
    </div>
  </div>
</section>
