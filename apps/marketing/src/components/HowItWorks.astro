---
import { Filter, Globe } from 'lucide-astro';

import FeatureIcon from './FeatureIcon.astro';
import { strings, type Locale } from '../i18n';

interface Props {
  lang?: Locale;
}

const { lang = 'en' } = Astro.props;
const t = strings[lang].howItWorks;
---

<section id="how-it-works" class="border-t border-border bg-surface px-6 py-20">
  <div class="mx-auto max-w-3xl">
    <h2 class="font-display text-3xl font-extrabold tracking-display text-ink-strong sm:text-4xl">
      {t.sectionTitle}
    </h2>
    <p class="mt-3 text-ink-soft">
      {t.sectionLead}
    </p>

    <div class="mt-12 space-y-10">
      {
        t.steps.map((step, i) => (
          <div class="flex items-start gap-5">
            <FeatureIcon class="mt-1">
              {i === 0 ? <Globe class="size-6" /> : <Filter class="size-6" />}
            </FeatureIcon>
            <div>
              <div class="flex flex-wrap items-center gap-x-3 gap-y-1">
                <h3 class="font-display text-xl font-bold text-ink-strong">{step.title}</h3>
                {step.badge && (
                  <span class="rounded-full border border-border bg-bg px-3 py-1 text-xs font-semibold text-ink-soft">
                    {step.badge}
                  </span>
                )}
              </div>
              <p class="mt-2 leading-relaxed text-ink-soft">{step.body}</p>
              {step.note && (
                <p class="mt-3 text-sm italic text-ink-soft">* {step.note}</p>
              )}
            </div>
          </div>
        ))
      }
    </div>
  </div>
</section>
