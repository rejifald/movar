---
import { strings, type Locale } from '../i18n';

interface Props {
  lang?: Locale;
}

const { lang = 'en' } = Astro.props;
const t = strings[lang].howItWorks;
---

<section id="how-it-works" class="border-t border-border bg-surface px-6 py-20">
  <div class="mx-auto max-w-3xl">
    <h2 class="font-display text-3xl font-extrabold tracking-tight text-ink-strong sm:text-4xl">
      {t.sectionTitle}
    </h2>
    <p class="mt-3 text-ink-soft">
      {t.sectionLead}
    </p>

    <div class="mt-12 space-y-10">
      {
        t.steps.map((step, i) => (
          <div class="flex items-start gap-5">
            <div class="flex size-12 shrink-0 items-center justify-center rounded-xl bg-accent-surface text-accent-deep">
              {i === 0 ? (
                <svg
                  class="size-6"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  aria-hidden="true"
                >
                  <circle cx="12" cy="12" r="10" />
                  <path d="M2 12h20" />
                  <path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10Z" />
                </svg>
              ) : (
                <svg
                  class="size-6"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  aria-hidden="true"
                >
                  <polygon points="22 3 2 3 10 12.46 10 19 14 21 14 12.46 22 3" />
                </svg>
              )}
            </div>
            <div>
              <div class="flex flex-wrap items-center gap-x-3 gap-y-1">
                <h3 class="font-display text-xl font-bold text-ink-strong">{step.title}</h3>
                {step.badge && (
                  <span class="rounded-full border border-border bg-bg px-2.5 py-0.5 text-xs font-semibold text-ink-soft">
                    {step.badge}
                  </span>
                )}
              </div>
              <p class="mt-2 leading-relaxed text-ink-soft">{step.body}</p>
              {step.note && (
                <p class="mt-3 text-sm italic text-ink-soft">* {step.note}</p>
              )}
            </div>
          </div>
        ))
      }
    </div>
  </div>
</section>
