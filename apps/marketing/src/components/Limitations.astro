---
import { strings, type Locale } from '../i18n';

interface Props {
  lang?: Locale;
}

const { lang = 'en' } = Astro.props;
const t = strings[lang].limitations;
---

<section id="limitations" class="border-t border-border bg-bg px-6 py-20">
  <div class="mx-auto max-w-3xl">
    <h2 class="font-display text-3xl font-extrabold tracking-tight text-ink-strong sm:text-4xl">
      {t.sectionTitle}
    </h2>
    <p class="mt-3 max-w-2xl text-ink-soft">
      {t.sectionLead}
    </p>

    <ul class="mt-10 space-y-5">
      {
        t.items.map((item) => (
          <li class="flex items-start gap-3">
            <svg
              class="mt-1 size-5 shrink-0 text-ink-faint"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              aria-hidden="true"
            >
              <circle cx="12" cy="12" r="9" />
              <line x1="5.6" y1="5.6" x2="18.4" y2="18.4" />
            </svg>
            <p class="leading-relaxed text-ink-soft">{item}</p>
          </li>
        ))
      }
    </ul>
  </div>
</section>
