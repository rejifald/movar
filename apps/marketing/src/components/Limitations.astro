---
import { strings, type Locale } from '../i18n';

interface Props {
  lang?: Locale;
}

const { lang = 'en' } = Astro.props;
const t = strings[lang].limitations;
---

<section id="limitations" class="border-t border-border bg-bg px-6 py-20">
  <div class="mx-auto max-w-3xl">
    <h2 class="font-display text-3xl font-extrabold tracking-tight text-ink-strong sm:text-4xl">
      {t.sectionTitle}
    </h2>
    <p class="mt-3 max-w-2xl text-ink-soft">
      {t.sectionLead}
    </p>

    <ul class="mt-10 space-y-5">
      {
        t.items.map((item, i) => (
          <li class="flex items-start gap-3">
            <span
              class="mt-0.5 shrink-0 font-display text-sm font-bold tabular-nums text-accent"
              aria-hidden="true"
            >
              {String(i + 1).padStart(2, '0')}
            </span>
            <p class="leading-relaxed text-ink">{item}</p>
          </li>
        ))
      }
    </ul>
  </div>
</section>
