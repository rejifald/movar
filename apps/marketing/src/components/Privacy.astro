---
/*
 * Privacy claim. Echoes the short version on /privacy and links there
 * for the full policy.
 *
 * Sits right after HowItWorks so it amplifies the "runs entirely in
 * your browser — nothing leaves it" line in that section's lead, while
 * the reader is still thinking about mechanism (and the natural
 * "where does my data go?" follow-up that raises).
 */
import { ShieldCheck } from 'lucide-astro';

import FeatureIcon from './FeatureIcon.astro';
import { strings, type Locale, localePrivacyHref } from '../i18n';

interface Props {
  lang?: Locale;
}

const { lang = 'en' } = Astro.props;
const t = strings[lang].privacy;
---

<section id="privacy-callout" class="border-t border-border bg-bg px-6 py-20">
  <div class="mx-auto max-w-3xl">
    <div class="flex items-start gap-4">
      <FeatureIcon class="mt-1">
        <ShieldCheck class="size-6" />
      </FeatureIcon>
      <div>
        <h2
          class="font-display text-3xl font-extrabold tracking-tight text-ink-strong sm:text-4xl"
        >
          {t.sectionTitle}
        </h2>
        <p class="mt-4 text-ink-soft leading-relaxed">
          {t.sectionLead}
        </p>
        <p class="mt-6">
          <a
            href={localePrivacyHref(lang)}
            class="inline-flex items-center gap-1 text-sm font-semibold text-accent hover:underline"
          >
            {t.linkLabel}
            <span aria-hidden="true">→</span>
          </a>
        </p>
      </div>
    </div>
  </div>
</section>
