---
import { strings, type Locale, localeWhyThisHappensHref } from '../i18n';

interface Props {
  lang?: Locale;
}

const { lang = 'en' } = Astro.props;
const t = strings[lang].problem;
const deepDiveHref = localeWhyThisHappensHref(lang);
---

<section id="why" class="border-t border-border bg-bg px-6 py-20">
  <div class="mx-auto max-w-3xl">
    <p class="font-display text-xs font-bold uppercase tracking-label text-accent">
      {t.sectionTitle}
    </p>
    <h2
      class="mt-3 font-display text-3xl font-extrabold tracking-display text-ink-strong sm:text-4xl"
    >
      {t.sectionLead}
    </h2>

    <ul class="mt-10 space-y-6">
      {
        t.facts.map((fact) => (
          <li>
            <p class="font-display text-lg font-bold text-ink-strong">{fact.heading}</p>
            <p class="mt-1 text-ink-soft leading-relaxed">{fact.body}</p>
          </li>
        ))
      }
    </ul>

    <p class="mt-10 text-lg font-medium text-ink-strong">
      {t.closeLine}
    </p>
    <p class="mt-4">
      <a
        href={deepDiveHref}
        class="inline-flex items-center gap-1 text-sm font-semibold text-accent hover:underline"
      >
        {t.deepDiveLinkLabel}
        <span aria-hidden="true">→</span>
      </a>
    </p>
  </div>
</section>
