---
import { strings, type Locale } from '../i18n';
import { Unlink } from 'lucide-astro';

interface Props {
  lang?: Locale;
}

const { lang = 'en' } = Astro.props;
const t = strings[lang].stakes;
---

<section id="why-it-matters" class="border-t border-border bg-bg px-6 py-20">
  <div class="mx-auto max-w-3xl">
    <p class="font-display text-xs font-bold uppercase tracking-wider text-accent">
      {t.sectionTitle}
    </p>
    <h2
      class="mt-3 font-display text-3xl font-extrabold tracking-tight text-ink-strong sm:text-4xl"
    >
      {t.sectionLead}
    </h2>

    <ul class="mt-10 space-y-6">
      {
        t.facts.map((fact) => (
          <li>
            <p class="font-display text-lg font-bold text-ink-strong">{fact.heading}</p>
            <p class="mt-1 text-ink-soft leading-relaxed">{fact.body}</p>
          </li>
        ))
      }
    </ul>

    <p
      class="mt-12 flex items-start gap-3 font-display text-xl font-bold text-ink-strong sm:text-2xl"
    >
      <Unlink class="mt-1 size-6 shrink-0 text-accent" aria-hidden="true" />
      <span>{t.closeLine}</span>
    </p>
  </div>
</section>
