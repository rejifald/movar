---
import '../styles/global.css';
import { strings, type Locale } from '../i18n';

interface Props {
  lang?: Locale;
  title?: string;
  description?: string;
}

const { lang = 'en', title, description } = Astro.props;
const t = strings[lang];
const resolvedTitle = title ?? t.meta.defaultTitle;
const resolvedDescription = description ?? t.meta.defaultDescription;

const canonicalURL = new URL(Astro.url.pathname, Astro.site).toString();
const ogImageURL = new URL('/og-image.svg', Astro.site).toString();
---

<!doctype html>
<html lang={t.meta.htmlLang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    {/*
     * Locale auto-detection. Movar's whole pitch is "we pick your language
     * for you" — the marketing site has to walk the talk, so we redirect
     * before render instead of nagging visitors with a banner. The class
     * stamp on <html> lets CSS hide UK-pointing affordances for readers
     * who don't have uk in their navigator languages. sessionStorage holds
     * a manual override so clicking the header switcher sticks.
     */}
    <script is:inline>
      (function () {
        try {
          var langs =
            navigator.languages && navigator.languages.length
              ? navigator.languages
              : [navigator.language || ''];
          var wantsUK = langs.some(function (l) {
            return l && l.toLowerCase().slice(0, 2) === 'uk';
          });
          document.documentElement.classList.add(wantsUK ? 'lang-prefers-uk' : 'lang-no-uk');

          if (sessionStorage.getItem('movar_locale_choice')) return;

          var path = location.pathname;
          var isUK = path === '/uk' || path.indexOf('/uk/') === 0;

          if (!isUK && wantsUK) {
            var to = path === '/' ? '/uk/' : '/uk' + path;
            location.replace(to + location.search + location.hash);
          } else if (isUK && !wantsUK) {
            var stripped = path.replace(/^\/uk/, '') || '/';
            location.replace(stripped + location.search + location.hash);
          }
        } catch (_) {
          /* Wrong locale is better than a broken page. */
        }
      })();
    </script>
    <meta name="generator" content={Astro.generator} />
    <title>{resolvedTitle}</title>
    <meta name="description" content={resolvedDescription} />
    <link rel="canonical" href={canonicalURL} />
    <link rel="icon" type="image/svg+xml" href="/icon.svg" />
    <meta name="theme-color" content="#1C1917" />

    {/* Open Graph */}
    <meta property="og:type" content="website" />
    <meta property="og:title" content={resolvedTitle} />
    <meta property="og:description" content={resolvedDescription} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:site_name" content="Movar" />
    <meta property="og:locale" content={lang === 'uk' ? 'uk_UA' : 'en'} />
    <meta property="og:image" content={ogImageURL} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />

    {/* Twitter */}
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={resolvedTitle} />
    <meta name="twitter:description" content={resolvedDescription} />
    <meta name="twitter:image" content={ogImageURL} />
  </head>
  <body class="min-h-screen flex flex-col bg-bg text-ink">
    <slot />
  </body>
</html>
