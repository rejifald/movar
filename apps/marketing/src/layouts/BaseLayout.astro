---
import '../styles/global.css';
import { strings, type Locale } from '../i18n';

interface Props {
  lang?: Locale;
  title?: string;
  description?: string;
}

const { lang = 'en', title, description } = Astro.props;
const t = strings[lang];
const resolvedTitle = title ?? t.meta.defaultTitle;
const resolvedDescription = description ?? t.meta.defaultDescription;

const canonicalURL = new URL(Astro.url.pathname, Astro.site).toString();
const ogImageURL = new URL('/og-image.svg', Astro.site).toString();
---

<!doctype html>
<html lang={t.meta.htmlLang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <title>{resolvedTitle}</title>
    <meta name="description" content={resolvedDescription} />
    <link rel="canonical" href={canonicalURL} />
    <link rel="icon" type="image/svg+xml" href="/icon.svg" />
    <meta name="theme-color" content="#1C1917" />

    {/* Open Graph */}
    <meta property="og:type" content="website" />
    <meta property="og:title" content={resolvedTitle} />
    <meta property="og:description" content={resolvedDescription} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:site_name" content="Movar" />
    <meta property="og:locale" content={lang === 'uk' ? 'uk_UA' : 'en'} />
    <meta property="og:image" content={ogImageURL} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />

    {/* Twitter */}
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={resolvedTitle} />
    <meta name="twitter:description" content={resolvedDescription} />
    <meta name="twitter:image" content={ogImageURL} />
  </head>
  <body class="min-h-screen flex flex-col bg-bg text-ink">
    <slot />
    <script>
      (function () {
        const dismissed = localStorage.getItem('movar_locale_banner_dismissed');
        if (dismissed === 'true') return;

        const pathname = window.location.pathname;
        const isUK = pathname.startsWith('/uk/');
        const userLang = navigator.language;
        const userWantsUK = userLang.startsWith('uk');

        let show = false, target = '', msg = '';

        if (!isUK && userWantsUK) {
          show = true;
          target = pathname === '/' ? '/uk/' : '/uk' + pathname;
          msg = 'Доступно українською';
        } else if (isUK && !userWantsUK) {
          show = true;
          target = pathname.replace(/^\/uk\/?/, '/');
          msg = 'Available in English';
        }

        if (!show) return;

        const banner = document.createElement('div');
        banner.className = 'fixed top-0 left-0 right-0 z-[60] bg-accent-surface px-4 py-3 flex items-center justify-between gap-4';
        banner.innerHTML = `
          <a href="${target}" class="text-sm text-accent underline hover:no-underline">${msg} →</a>
          <button type="button" class="inline-flex items-center justify-center w-11 h-11 text-ink hover:text-ink-strong cursor-pointer" aria-label="Dismiss">×</button>
        `;

        banner.querySelector('button')?.addEventListener('click', () => {
          localStorage.setItem('movar_locale_banner_dismissed', 'true');
          banner.remove();
        });

        document.body.insertBefore(banner, document.body.firstChild);
      })();
    </script>
  </body>
</html>
