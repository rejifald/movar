---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Hero from '../components/Hero.astro';
import Problem from '../components/Problem.astro';
import Stakes from '../components/Stakes.astro';
import HowItWorks from '../components/HowItWorks.astro';
import Examples from '../components/Examples.astro';
import BeforeAfter from '../components/BeforeAfter.astro';
import Limitations from '../components/Limitations.astro';
import Privacy from '../components/Privacy.astro';
import Close from '../components/Close.astro';
import Footer from '../components/Footer.astro';
---

<BaseLayout lang="en">
