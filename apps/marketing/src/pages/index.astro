  <main class="flex-1">
    <Hero lang="en" />
    <Problem lang="en" />
    <Stakes lang="en" />
    <HowItWorks lang="en" />
    <Privacy lang="en" />
    <Examples lang="en" />
    <BeforeAfter lang="en" />
    <Limitations lang="en" />
    <Close lang="en" />
