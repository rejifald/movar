{
  "name": "safari-onboarding",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "projectType": "application",
  "sourceRoot": "apps/safari-onboarding/src",
  "targets": {
    "dev": {
      "executor": "nx:run-commands",
      "options": { "command": "vite", "cwd": "apps/safari-onboarding" }
    },
    "build": {
      "executor": "nx:run-commands",
      "options": {
        "command": "vite build && tsx scripts/sync-safari-app.mts",
        "cwd": "apps/safari-onboarding"
      },
      "cache": true
    },
    "preview": {
      "executor": "nx:run-commands",
      "options": { "command": "vite preview", "cwd": "apps/safari-onboarding" }
    },
    "typecheck": {
      "executor": "nx:run-commands",
      "options": { "command": "tsc --noEmit", "cwd": "apps/safari-onboarding" },
      "cache": true
    },
    "lint": {
      "executor": "nx:run-commands",
      "options": {
        "command": "eslint . --cache --cache-location node_modules/.eslintcache",
        "cwd": "apps/safari-onboarding"
      },
      "cache": true
    },
    "test": {
      "executor": "nx:run-commands",
      "options": { "command": "vitest run", "cwd": "apps/safari-onboarding" },
      "cache": true
    }
  }
}
