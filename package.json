{
  "name": "movar",
  "version": "0.0.0",
  "private": true,
  "description": "Movar — keep the internet in your language. A cross-browser extension enforcing your language preferences (UA first, EN fallback).",
  "packageManager": "pnpm@11.3.0",
  "engines": {
    "node": ">=22",
    "pnpm": ">=11"
  },
  "scripts": {
    "dev": "process-compose up -U -u /tmp/movar-pc.sock",
    "dev:extension": "nx run extension:dev",
    "build": "nx run-many -t build",
    "lint:root": "eslint tooling/ eslint.config.mjs --cache --cache-location node_modules/.eslintcache",
    "lint": "pnpm lint:root && nx run-many -t lint",
    "lint:suppress": "tsx scripts/eslint-suppress.mts",
    "lint:prune": "tsx scripts/eslint-suppress.mts --prune",
    "typecheck": "nx run-many -t typecheck",
    "test": "nx run-many -t test --exclude=e2e",
    "test:coverage": "NX_NATIVE_COMMAND_RUNNER=false nx run-many -t test --exclude=e2e --skip-nx-cache -- --coverage",
    "test:e2e:live": "nx run e2e:test:live",
    "test:e2e:live:headed": "nx run e2e:test:live:headed",
    "test:e2e:fast": "nx run e2e:test:fast",
    "test:edge-poll": "bash scripts/edge-poll-gate.test.sh",
    "test:action-pins": "tsx scripts/check-action-pins.test.mts",
    "test:metrics-gate": "tsx scripts/metrics-gate.test.mts",
    "test:promises": "tsx scripts/lib/promises.test.mts",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "check:readme": "tsx scripts/check-readme-parity.mts --self-test && tsx scripts/check-readme-parity.mts && tsx scripts/gen-readme-metrics.mts --check",
    "gen:readme": "tsx scripts/gen-readme-metrics.mts",
    "check:suppressions": "tsx scripts/check-suppressions.mts",
    "check:release-governance": "tsx scripts/check-release-governance.mts",
    "check:action-pins": "tsx scripts/check-action-pins.mts",
    "check:content-bundle": "pnpm --filter @movar/extension check:content-bundle",
    "publint": "pnpm --workspace-concurrency=1 --filter @movar/brand --filter @movar/events --filter @movar/settings --filter @movar/host-match --filter @movar/lang-detect exec publint",
    "validate": "pnpm typecheck && pnpm lint && pnpm test && pnpm publint && pnpm check:readme && pnpm check:suppressions && pnpm check:release-governance && pnpm check:action-pins && pnpm check:content-bundle",
    "build:artifacts": "bash scripts/build-artifacts.sh",
    "verify:release": "bash scripts/verify-release.sh",
    "pack:amo-source": "bash scripts/pack-amo-source.sh",
    "get:cws-refresh-token": "node scripts/get-cws-refresh-token.mjs",
    "capture:storybook-assets": "pnpm --filter @movar/extension capture:storybook-assets",
    "metrics": "mkdir -p .metrics; fallow --format markdown --score --save-snapshot > .metrics/fallow.md; fallow --format json --score > .metrics/fallow.json; tsx scripts/fallow-targets.mts; pnpm test:coverage; pnpm --filter @movar/extension check:content-bundle; tsx scripts/gen-readme-metrics.mts --refresh",
    "metrics:audit": "fallow audit --base origin/main",
    "metrics:targets": "tsx scripts/fallow-targets.mts",
    "metrics:baseline": "fallow --save-regression-baseline .fallow/regression-baseline.json",
    "metrics:check": "fallow --fail-on-regression --tolerance 0 --regression-baseline .fallow/regression-baseline.json",
    "changeset": "changeset",
    "prepare": "lefthook install || true"
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.0",
    "@commitlint/cli": "^21.0.1",
    "@commitlint/config-conventional": "^21.0.1",
    "@commitlint/types": "^21.0.1",
    "@movar/eslint-config": "workspace:*",
    "eslint": "^9.39.4",
    "fallow": "^2.80.0",
    "jsdom": "^29.1.1",
    "lefthook": "^2.1.8",
    "nx": "^22.7.3",
    "prettier": "^3.8.3",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "publint": "^0.3.21",
    "tsx": "^4.22.3",
    "typescript": "^6.0.3",
    "vitest": "^4.1.7",
    "wrangler": "^4.95.0"
  }
}
