{
  "name": "host-match",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "projectType": "library",
  "sourceRoot": "packages/host-match/src",
  "targets": {
    "typecheck": {
      "executor": "nx:run-commands",
      "options": { "command": "tsc --noEmit", "cwd": "packages/host-match" },
      "cache": true
    },
    "lint": {
      "executor": "nx:run-commands",
      "options": {
        "command": "eslint . --cache --cache-location node_modules/.eslintcache",
        "cwd": "packages/host-match"
      },
      "cache": true
    },
    "test": {
      "executor": "nx:run-commands",
      "options": { "command": "vitest run", "cwd": "packages/host-match" },
      "cache": true
    }
  }
}
