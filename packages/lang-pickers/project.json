{
  "name": "lang-pickers",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "projectType": "library",
  "sourceRoot": "packages/lang-pickers/src",
  "targets": {
    "typecheck": {
      "executor": "nx:run-commands",
      "options": { "command": "tsc --noEmit", "cwd": "packages/lang-pickers" },
      "cache": true
    },
    "lint": {
      "executor": "nx:run-commands",
      "options": { "command": "eslint .", "cwd": "packages/lang-pickers" },
      "cache": true
    },
    "test": {
      "executor": "nx:run-commands",
      "options": { "command": "vitest run", "cwd": "packages/lang-pickers" },
      "cache": true
    }
  }
}
