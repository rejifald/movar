{
  "name": "ui",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "projectType": "library",
  "sourceRoot": "packages/ui/src",
  "targets": {
    "typecheck": {
      "executor": "nx:run-commands",
      "options": { "command": "tsc --noEmit", "cwd": "packages/ui" },
      "cache": true
    },
    "lint": {
      "executor": "nx:run-commands",
      "options": {
        "command": "eslint . --cache --cache-location node_modules/.eslintcache",
        "cwd": "packages/ui"
      },
      "cache": true
    },
    "test": {
      "executor": "nx:run-commands",
      "options": { "command": "vitest run --passWithNoTests", "cwd": "packages/ui" },
      "cache": true
    },
    "storybook": {
      "executor": "nx:run-commands",
      "options": { "command": "pnpm storybook", "cwd": "packages/ui" }
    },
    "build-storybook": {
      "executor": "nx:run-commands",
      "options": { "command": "pnpm build-storybook", "cwd": "packages/ui" },
      "outputs": ["{projectRoot}/storybook-static"],
      "cache": true
    }
  }
}
