{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "strict": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noUncheckedIndexedAccess": true,
    "forceConsistentCasingInFileNames": true,
    "declaration": true,
    "jsx": "react-jsx",
    "paths": {
      "@movar/shared": ["./packages/shared/src/index.ts"],
      "@movar/lang-detect": ["./packages/lang-detect/src/index.ts"],
      "@movar/rules": ["./packages/rules/src/index.ts"]
    }
  }
}
